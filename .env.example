# Backend environment variables — copy this file to .env and fill in all values
# NEVER commit .env to Git

# ── Database ──────────────────────────────────────────────────────────────────
# Get from: console.neon.tech → your project → Connection Details → Pooled connection
DATABASE_URL=postgresql://USER:PASSWORD@ep-square-pine-ai3hqjbw-pooler.c-4.us-east-1.aws.neon.tech/DBNAME?sslmode=require

# Direct (non-pooled) connection — used by prisma migrate
# Get from: console.neon.tech → your project → Connection Details → Direct connection
DIRECT_URL=postgresql://USER:PASSWORD@ep-square-pine-ai3hqjbw.c-4.us-east-1.aws.neon.tech/DBNAME?sslmode=require

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Clerk Auth ────────────────────────────────────────────────────────────────
# Get from: dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
